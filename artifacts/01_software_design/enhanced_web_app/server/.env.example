# Environment configuration template for the CS360 Inventory Server.
# Author: Sanjay Chauhan
# Date: 2026-05-24
# CS499 Enhancement One rebuild of the CS360 Android Inventory App.
#
# Copy this file to ".env" and replace the placeholder secret before running.

# Secret used to sign and verify JWTs. Use a long, random string in production.
JWT_SECRET=change_me_to_a_long_random_string

# Port the Express server listens on.
PORT=4000
