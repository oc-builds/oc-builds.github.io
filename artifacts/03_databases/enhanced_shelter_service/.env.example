# .env.example
#
# Copy to `.env` and fill in real values before running the API or any of the
# helper scripts. config.py refuses to import if either of these is missing,
# which is the intended fail-fast behavior -- silent default credentials are
# exactly what the CS340 original got dinged for.

# MongoDB connection string. Format: mongodb://[user:pass@]host:port/dbname
# The docker-compose path uses no auth at the Mongo URL because Mongo-side
# auth is layered in by db_setup.py via createRole/createUser, and the API
# layer uses a single service-account connection. See README for details.
MONGO_URI=mongodb://localhost:27017/aac

# JWT signing secret. MUST be a long random string in any non-toy use.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change_me_to_a_long_random_string

# ---------------------------------------------------------------------------
# M7 DB-tier isolation (OPTIONAL). Leave ALL of these blank for the default
# single-service-account behavior a grader expects. Set them to enable a
# second enforcement tier where each JWT role connects to Mongo with a
# credential whose Mongo-side privileges match that role. See README
# "Hardening (Module 7)". The JWT require_role checks run either way.
# ---------------------------------------------------------------------------
# Per-role connection URIs consumed by app/db_provider.py:
# MONGO_URI_ADMIN=mongodb://aac_admin:<pw>@localhost:27017/aac?authSource=aac
# MONGO_URI_STAFF=mongodb://aac_staff:<pw>@localhost:27017/aac?authSource=aac
# MONGO_URI_VIEWER=mongodb://aac_viewer:<pw>@localhost:27017/aac?authSource=aac
#
# Passwords for the Mongo users that scripts/db_setup.py provisions. If unset,
# db_setup.py SKIPS user creation (no default passwords are ever written):
# MONGO_ADMIN_PASSWORD=
# MONGO_STAFF_PASSWORD=
# MONGO_VIEWER_PASSWORD=
